      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "质量目标" } }
    } },
    "Optimization level" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Optimizasyon düzeyi" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Optimierungsstufe" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Niveau d'optimisation" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Nivel de optimización" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "最適化レベル" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "优化级别" } }
    } },
    "Level" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Düzey" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Stufe" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Niveau" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Nivel" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "レベル" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "级别" } }
    } },
    "Quick single-pass compression. Good for large batches." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Hızlı tek geçişli sıkıştırma. Büyük gruplar için uygundur." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Schnelle Kompression in einem Durchgang. Gut für große Stapel." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Compression rapide en une passe. Idéal pour les gros lots." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Compresión rápida de una sola pasada. Ideal para lotes grandes." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "1パスの高速圧縮。大量処理に最適。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "快速单遍压缩。适合大批量处理。" } }
    } },
    "Balanced effort: the sweet spot for everyday use." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dengeli çaba: günlük kullanım için ideal nokta." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Ausgewogener Aufwand: der ideale Punkt für den Alltag." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Effort équilibré : le bon compromis au quotidien." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Esfuerzo equilibrado: el punto justo para el día a día." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "バランスの取れた設定。日常使いに最適。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "均衡的力度：日常使用的最佳选择。" } }
    } },
    "Exhaustive compression trials. Noticeably slower on big images." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Kapsamlı sıkıştırma denemeleri. Büyük görsellerde belirgin şekilde yavaş." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Erschöpfende Kompressionsversuche. Bei großen Bildern deutlich langsamer." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Essais de compression exhaustifs. Nettement plus lent sur les grandes images." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Pruebas de compresión exhaustivas. Bastante más lento con imágenes grandes." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "徹底的な圧縮試行。大きな画像では明らかに遅くなります。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "穷尽式压缩尝试。大图像明显更慢。" } }
    } },
    "Adds Zopfli deflate to PNGs. Can take minutes per image, saves the last few percent." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "PNG'lere Zopfli deflate ekler. Görsel başına dakikalar sürebilir, son birkaç yüzdeyi kazandırır." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Fügt PNGs Zopfli-Deflate hinzu. Kann Minuten pro Bild dauern, spart die letzten Prozent." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ajoute Zopfli aux PNG. Peut prendre plusieurs minutes par image, gagne les derniers pourcents." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Añade Zopfli a los PNG. Puede tardar minutos por imagen y ahorra los últimos porcentajes." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "PNGにZopfli deflateを追加。1枚に数分かかることもありますが、最後の数パーセントを削減します。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "为PNG添加Zopfli deflate。每张图可能耗时数分钟，可节省最后几个百分点。" } }
    } },
    "Parallelism" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Paralellik" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Parallelität" } },
