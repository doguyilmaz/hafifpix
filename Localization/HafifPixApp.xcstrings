      "es" : { "stringUnit" : { "state" : "translated", "value" : "Escritura de archivos" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ファイルの書き込み" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "文件写入" } }
    } },
    "Preserve file permissions and attributes" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dosya izinlerini ve özniteliklerini koru" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Dateiberechtigungen und -attribute erhalten" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Préserver les permissions et attributs des fichiers" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Conservar permisos y atributos de los archivos" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ファイルの権限と属性を保持" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保留文件权限和属性" } }
    } },
    "Preserve file creation and modification dates" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dosya oluşturma ve değiştirme tarihlerini koru" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Erstellungs- und Änderungsdatum erhalten" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Préserver les dates de création et de modification" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Conservar fechas de creación y modificación" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ファイルの作成日と変更日を保持" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保留文件创建和修改日期" } }
    } },
    "Originals" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Orijinaller" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Originale" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Originaux" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Originales" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "オリジナル" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "原始文件" } }
    } },
    "Regardless of this setting, every file can be reverted from the right-click menu while the app is open." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Bu ayardan bağımsız olarak, uygulama açıkken her dosya sağ tık menüsünden geri alınabilir." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Unabhängig von dieser Einstellung lässt sich jede Datei über das Kontextmenü zurücksetzen, solange die App geöffnet ist." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quel que soit ce réglage, chaque fichier peut être rétabli via le menu contextuel tant que l'app est ouverte." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Independientemente de este ajuste, cada archivo puede restaurarse desde el menú contextual mientras la app esté abierta." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "この設定に関わらず、アプリを開いている間は右クリックメニューからどのファイルも元に戻せます。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无论此设置如何，应用打开期间任何文件都可通过右键菜单还原。" } }
    } },
    "Enable lossy minification" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Kayıplı küçültmeyi etkinleştir" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Verlustbehaftete Verkleinerung aktivieren" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Activer la minification avec perte" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Activar minificación con pérdida" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "非可逆圧縮を有効にする" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用有损压缩" } }
    } },
    "Makes files much smaller, but may subtly change how images look." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dosyaları çok daha küçük yapar ancak görsellerin görünümünü hafifçe değiştirebilir." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Macht Dateien deutlich kleiner, kann das Aussehen der Bilder aber leicht verändern." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Réduit fortement la taille des fichiers, mais peut légèrement modifier l'apparence des images." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Hace los archivos mucho más pequeños, pero puede cambiar sutilmente el aspecto de las imágenes." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ファイルは大幅に小さくなりますが、画像の見た目がわずかに変わる場合があります。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "文件会小得多，但图像外观可能有细微变化。" } }
    } },
    "Quality targets" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Kalite hedefleri" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Qualitätsziele" } },
