      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "像素" } }
    } },
    "Larger images are downscaled before compression. Animations are resized too (GIF)." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Daha büyük görseller sıkıştırmadan önce küçültülür. Animasyonlar da yeniden boyutlandırılır (GIF)." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Größere Bilder werden vor der Kompression verkleinert. Auch Animationen (GIF)." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les images plus grandes sont réduites avant compression. Les animations aussi (GIF)." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Las imágenes más grandes se reducen antes de comprimir. Las animaciones también (GIF)." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "大きい画像は圧縮前に縮小されます。アニメーション（GIF）も対象です。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "较大的图像会在压缩前缩小。动画（GIF）同样处理。" } }
    } },
    "Convert to modern formats" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Modern formatlara dönüştür" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "In moderne Formate konvertieren" } },
