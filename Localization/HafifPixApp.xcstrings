      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "转换为现代格式" } }
    } },
    "Convert images to" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Görselleri şuna dönüştür" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Bilder konvertieren in" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Convertir les images en" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Convertir imágenes a" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "変換先" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "将图像转换为" } }
    } },
    "Move original to Trash when converted file is smaller" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dönüştürülen dosya daha küçükse orijinali Çöp Sepeti'ne taşı" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Original in den Papierkorb legen, wenn die konvertierte Datei kleiner ist" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Déplacer l'original vers la corbeille si le fichier converti est plus petit" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Mover el original a la papelera si el archivo convertido es más pequeño" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "変換後のファイルが小さい場合はオリジナルをゴミ箱へ" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "转换后的文件更小时将原始文件移到废纸篓" } }
    } },
    "Converted files are written next to the original (photo.png → photo.%@). SVGs are minified as usual." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dönüştürülen dosyalar orijinalin yanına yazılır (photo.png → photo.%@). SVG'ler her zamanki gibi küçültülür." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Konvertierte Dateien entstehen neben dem Original (photo.png → photo.%@). SVGs werden wie üblich verkleinert." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les fichiers convertis sont créés à côté de l'original (photo.png → photo.%@). Les SVG sont minifiés comme d'habitude." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Los archivos convertidos se crean junto al original (photo.png → photo.%@). Los SVG se minifican como siempre." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "変換ファイルはオリジナルの隣に作成されます（photo.png → photo.%@）。SVGは通常どおり縮小されます。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "转换后的文件写在原始文件旁边（photo.png → photo.%@）。SVG照常缩小。" } }
    } },
    "Language" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dil" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Sprache" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Langue" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Idioma" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "言語" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "语言" } }
    } },
    "System Default" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Sistem Varsayılanı" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Systemstandard" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Réglage du système" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Predeterminado del sistema" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "システムのデフォルト" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "系统默认" } }
    } },
    "Takes effect after the app is relaunched." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Uygulama yeniden başlatıldığında etkinleşir." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Wird nach einem Neustart der App wirksam." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Prend effet après le relancement de l'app." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Se aplica tras relanzar la app." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "アプリの再起動後に有効になります。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重新启动应用后生效。" } }
    } },
    "Relaunch Now" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Şimdi Yeniden Başlat" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Jetzt neu starten" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Relancer maintenant" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Relanzar ahora" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "今すぐ再起動" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "立即重新启动" } }
    } },
    "Every engine's output is only kept when it is smaller and still decodes correctly. Disabling engines mainly trades savings for speed." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Her motorun çıktısı yalnızca daha küçükse ve doğru çözülüyorsa kullanılır. Motorları kapatmak çoğunlukla kazanç yerine hız kazandırır." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Ausgabe jeder Engine wird nur übernommen, wenn sie kleiner ist und korrekt dekodiert. Engines zu deaktivieren tauscht vor allem Ersparnis gegen Tempo." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "La sortie de chaque moteur n'est conservée que si elle est plus petite et se décode correctement. Désactiver des moteurs échange surtout du gain contre de la vitesse." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "La salida de cada motor solo se conserva si es más pequeña y se decodifica correctamente. Desactivar motores intercambia sobre todo ahorro por velocidad." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "各エンジンの出力は、より小さく正しくデコードできる場合のみ採用されます。エンジンを無効にすると、主に削減率と引き換えに速度が上がります。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每个引擎的输出只有在更小且能正确解码时才会保留。停用引擎主要是用节省换取速度。" } }
    } }
  }
}
