      "es" : { "stringUnit" : { "state" : "translated", "value" : "Eliminar metadatos JPEG" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "JPEGメタデータを削除" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "移除JPEG元数据" } }
    } },
    "EXIF, GPS position, color profiles, rotation. Keep it if you rely on embedded copyright info." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "EXIF, GPS konumu, renk profilleri, döndürme. Gömülü telif hakkı bilgisine ihtiyacınız varsa koruyun." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "EXIF, GPS-Position, Farbprofile, Ausrichtung. Behalten, falls eingebettete Urheberrechtsinfos benötigt werden." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "EXIF, position GPS, profils colorimétriques, rotation. À conserver si vous dépendez des informations de copyright intégrées." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "EXIF, posición GPS, perfiles de color, rotación. Consérvalos si dependes de la información de copyright integrada." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "EXIF、GPS位置情報、カラープロファイル、回転。埋め込まれた著作権情報が必要な場合は残してください。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "EXIF、GPS位置、颜色描述文件、旋转。若依赖内嵌版权信息请保留。" } }
    } },
    "Writing files" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dosya Yazma" } },
