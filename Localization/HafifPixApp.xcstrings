    } },
    "Gamma chunks, color profiles and optional chunks. Web browsers expect these removed." : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "Gama parçaları, renk profilleri ve isteğe bağlı parçalar. Web tarayıcıları bunların kaldırılmış olmasını bekler." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Gamma-Chunks, Farbprofile und optionale Chunks. Webbrowser erwarten, dass sie entfernt sind." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Chunks gamma, profils colorimétriques et chunks optionnels. Les navigateurs web s'attendent à leur suppression." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Chunks gamma, perfiles de color y chunks opcionales. Los navegadores esperan que se eliminen." } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ガンマチャンク、カラープロファイル、オプションのチャンク。Webブラウザはこれらが削除されていることを想定しています。" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Gamma块、颜色描述文件和可选块。网页浏览器期望这些被移除。" } }
    } },
    "Strip JPEG metadata" : { "localizations" : {
      "tr" : { "stringUnit" : { "state" : "translated", "value" : "JPEG meta verilerini kaldır" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "JPEG-Metadaten entfernen" } },
